POSTGRES_DB=pm_gateway_auth
POSTGRES_USER=pm_gateway_auth
POSTGRES_PASSWORD=pm_gateway_auth
GATEWAY_DB_PORT=5433
GATEWAY_DB_URL=jdbc:postgresql://localhost:${GATEWAY_DB_PORT}/${POSTGRES_DB}
GATEWAY_DB_USERNAME=${POSTGRES_USER}
GATEWAY_DB_PASSWORD=${POSTGRES_PASSWORD}

OAUTH_CLIENT_ID=your-google-client-id
OAUTH_CLIENT_SECRET=your-google-client-secret
JWT_SECRET_BASE64=replace-with-32-byte-base64-secret
ADMIN_USER=admin@example.com

PROJECT_MANAGER_BACKEND_URI=http://localhost:8081
PROJECT_MANAGER_BACKEND_STAGING_URI=http://localhost:8080
